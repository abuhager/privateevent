@{
    ViewBag.Title = "Welcome to UniEvents";
}
@{
    Context.Response.Headers["Cache-Control"] = "no-cache, no-store, must-revalidate";
    Context.Response.Headers["Pragma"] = "no-cache";
    Context.Response.Headers["Expires"] = "0";
}


<div class="container" style="margin-top: 50px;">
    <div class="text-center mb-4">
        <h2 style="font-weight: bold;">Welcome to UniEvents</h2>
        <div style="color: #666;">Your university event management platform</div>
    </div>

    <div class="row justify-content-center" style="gap: 20px;">
        <div class="col-md-3 card p-4 text-center" style="min-width:240px;">
            <span style="font-size:36px;color:#2574fb;">
                <i class="fa fa-calendar"></i>
            </span>
            <div class="fw-bold mt-2 mb-1">Manage Events</div>
            <div class="mb-3" style="color: #666; font-size:15px;">Create and manage university events</div>
            <a href="/Dashboard" class="btn btn-primary w-100">Go to Dashboard</a>
        </div>
        <div class="col-md-3 card p-4 text-center" style="min-width:240px;">
            <span style="font-size:36px;color:#2574fb;">
                <i class="fa fa-user-friends"></i>
            </span>
            <div class="fw-bold mt-2 mb-1">Add New Event</div>
            <div class="mb-3" style="color: #666;font-size:15px;">Create events for students</div>
            <a href="/Events/Create" class="btn btn-primary w-100">Create Event</a>
        </div>
        <div class="col-md-3 card p-4 text-center" style="min-width:240px;">
            <span style="font-size:36px;color:#2574fb;">
                <i class="fa fa-book"></i>
            </span>
            <div class="fw-bold mt-2 mb-1">Your Profile</div>
            <div class="mb-3" style="color: #666; font-size:15px;">View and edit your information</div>
            <a href="/Profile" class="btn btn-primary w-100">View Profile</a>
        </div>
    </div>
</div>
