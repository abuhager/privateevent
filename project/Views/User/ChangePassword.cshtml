@{
    ViewData["Title"] = "تغيير كلمة المرور";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-warning text-dark text-center py-3">
                    <h4 class="mb-0 fw-bold"><i class="fas fa-key me-2"></i> تغيير كلمة المرور</h4>
                </div>
                <div class="card-body p-4">

                    @if (TempData["error"] != null)
                    {
                        <div class="alert alert-danger text-center">
                            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["error"]
                        </div>
                    }

                    <form asp-action="ChangePassword" method="post">

                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted">كلمة المرور الحالية</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-unlock"></i></span>
                                <input type="password" name="currentPassword" class="form-control" placeholder="أدخل كلمة المرور القديمة" required />
                            </div>
                        </div>

                        <hr class="my-4 text-muted opacity-25">

                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted">كلمة المرور الجديدة</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-lock text-success"></i></span>
                                <input type="password" name="newPassword" class="form-control" placeholder="أدخل كلمة المرور الجديدة" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted">تأكيد كلمة المرور</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-check-circle text-success"></i></span>
                                <input type="password" name="confirmPassword" class="form-control" placeholder="أعد كتابة كلمة المرور الجديدة" required />
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning fw-bold py-2 shadow-sm">
                                <i class="fas fa-save me-2"></i> حفظ كلمة المرور الجديدة
                            </button>
                            <a asp-action="Profile" class="btn btn-outline-secondary fw-bold py-2">
                                إلغاء والعودة
                            </a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>