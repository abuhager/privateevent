@model IEnumerable<project.Models.Roll>

@{
    ViewData["Title"] = "حجوزاتي";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* تنسيق خاص للتاريخ عشان يبين زي الرزنامة */
    .date-box {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        width: 100px;
        color: white;
        border-radius: 5px 0 0 5px; /* تدوير الحواف من اليسار */
    }

    .day {
        font-size: 2.5rem;
        font-weight: bold;
        line-height: 1;
    }

    .month {
        font-size: 1.2rem;
        text-transform: uppercase;
    }

    /* تأثير التحويم */
    .ticket-card {
        transition: transform 0.3s ease;
        border: none;
    }

        .ticket-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
</style>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark"><i class="fas fa-ticket-alt text-primary"></i> تذاكري وحجوزاتي</h2>
            <p class="text-muted">استعرض سجل الفعاليات التي قمت بالتسجيل فيها</p>
        </div>
        <a asp-action="EventsList" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-plus"></i> حجز فعالية جديدة
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="far fa-calendar-times fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">لا يوجد حجوزات حتى الآن</h4>
            <a asp-action="EventsList" class="btn btn-outline-primary mt-3">تصفح الفعاليات المتاحة</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                // تحديد الألوان بناءً على الحالة
                string statusColor = item.States == "active" ? "bg-success" : "bg-danger";
                string borderColor = item.States == "active" ? "border-success" : "border-danger";
                string statusText = item.States == "active" ? "حجز مؤكد" : "تم الإلغاء";
                string opacityClass = item.States == "active" ? "" : "opacity-75"; // تخفيف لون الكرت الملغي

                <div class="col-lg-6 col-12 mb-4">
                    <div class="card shadow-sm ticket-card h-100 @opacityClass">
                        <div class="d-flex h-100">

                            <div class="date-box @statusColor p-3 text-center">
                                <span class="day">@item.Event.Date.ToString("dd")</span>
                                <span class="month">@item.Event.Date.ToString("MMM")</span>
                                <span class="small">@item.Event.Date.ToString("yyyy")</span>
                            </div>

                            <div class="card-body d-flex flex-column justify-content-between">
                                <div>
                                    <div class="d-flex justify-content-between align-items-start">
                                        <h5 class="card-title fw-bold mb-1">@item.Event.Title</h5>
                                        @if (item.States == "active")
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill">@statusText</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill">@statusText</span>
                                        }
                                    </div>

                                    <div class="text-muted small mt-2">
                                        <p class="mb-1"><i class="far fa-clock text-primary me-2"></i> @item.Event.StartTime</p>
                                        <p class="mb-0"><i class="fas fa-map-marker-alt text-danger me-2"></i> @item.Event.Location</p>
                                    </div>
                                </div>

                                <div class="mt-3 text-end">
                                    <a asp-controller="Student" asp-action="BookEvent" asp-route-eventId="@item.EventId"
                                       class="btn btn-sm btn-outline-dark stretched-link">
                                        التفاصيل وإدارة الحجز <i class="fas fa-arrow-left ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>