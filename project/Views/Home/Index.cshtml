@{
    ViewBag.Title = "جامعة الزيتونة";
}

<div class="container text-center" style="margin-top: 40px;">
    <div class="mb-4">
        <img src="~/images/zitouna.jpg" alt="جامعة الزيتونة" class="img-fluid rounded mb-3" style="max-height: 250px;">
        
        <h1 class="mt-3">جامعة الزيتونة</h1>
        <div style="color: #666; font-size: 22px;">نحو مستقبل أكاديمي مشرق</div>
        <div class="mt-2" style="color: #888;">منصة إدارة الفعاليات الجامعية - حيث يلتقي التعليم بالابتكار والتميز</div>
    </div>
    <div class="card p-4 mb-4 mx-auto" style="max-width:800px;">
        <h4 class="mb-3">نبذة عن الجامعة</h4>
        <div style="color: #444;">
            جامعة الزيتونة هي مؤسسة تعليمية رائدة تأسست بهدف تقديم تعليم عالي الجودة وتطوير قادة المستقبل. نحن نفخر بتوفير بيئة أكاديمية محفزة تجمع بين التميز الأكاديمي والابتكار والبحث العلمي من خلال منصة الفعاليات الجامعية، نسعى لإثراء تجربة الطلاب وتوفير فرص للتعلم وتطوير خارج الفصول الدراسية.
        </div>
    </div>
    <div class="row justify-content-center" style="gap: 20px;">
        <div class="col-lg-3 col-md-4 col-10 card p-4 text-center">
            <span style="font-size:32px;color:#178957;">
                <i class="fa fa-calendar"></i>
            </span>
            <div class="fw-bold mt-2">فعاليات متنوعة</div>
            <div class="mb-3" style="color: #666;">تصفح وحجز الفعاليات الجامعية المتنوعة</div>
        </div>
        <div class="col-lg-3 col-md-4 col-10 card p-4 text-center">
            <span style="font-size:32px;color:#178957;">
                <i class="fa fa-users"></i>
            </span>
            <div class="fw-bold mt-2">مجتمع طلابي</div>
            <div class="mb-3" style="color: #666;">تواصل مع زملائك الطلاب والأساتذة</div>
        </div>
        <div class="col-lg-3 col-md-4 col-10 card p-4 text-center">
            <span style="font-size:32px;color:#178957;">
                <i class="fa fa-trophy"></i>
            </span>
            <div class="fw-bold mt-2">إنجازات وتميز</div>
            <div class="mb-3" style="color: #666;">تتبع مشاركاتك وإنجازاتك الأكاديمية</div>
        </div>
        <div class="col-lg-3 col-md-4 col-10 card p-4 text-center">
            <span style="font-size:32px;color:#178957;">
                <i class="fa fa-book"></i>
            </span>
            <div class="fw-bold mt-2">ورش عمل</div>
            <div class="mb-3" style="color: #666;">احضر الندوات وورش العمل التطويرية</div>
        </div>
    </div>
</div>
