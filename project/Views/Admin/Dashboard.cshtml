@model List<project.Models.Event>
@{
    Context.Response.Headers["Cache-Control"] = "no-cache, no-store, must-revalidate";
    Context.Response.Headers["Pragma"] = "no-cache";
    Context.Response.Headers["Expires"] = "0";
    ViewBag.Title = "لوحة التحكم";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="fas fa-tachometer-alt text-success me-2"></i> لوحة التحكم
            </h2>
            <p class="text-muted mb-0">نظرة عامة وإدارة الفعاليات</p>
        </div>
        <a asp-action="CreateEvent" class="btn btn-success px-4 py-2 shadow-sm fw-bold rounded-pill hover-scale">
            <i class="fas fa-plus-circle me-2"></i> إضافة فعالية
        </a>
    </div>

    {{!-- ✅ KPI Cards --}}
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white border-0 shadow-sm h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-1 opacity-75">عدد الطلاب</h6>
                        <h2 class="mb-0 fw-bold">@ViewBag.StudentCount</h2>
                    </div>
                    <i class="fas fa-user-graduate fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white border-0 shadow-sm h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-1 opacity-75">الفعاليات المتاحة</h6>
                        <h2 class="mb-0 fw-bold">@ViewBag.EventCount</h2>
                    </div>
                    <i class="fas fa-calendar-check fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark border-0 shadow-sm h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-1 opacity-75">حجوزات نشطة</h6>
                        <h2 class="mb-0 fw-bold">@ViewBag.ActiveBookings</h2>
                    </div>
                    <i class="fas fa-ticket-alt fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white border-0 shadow-sm h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-1 opacity-75">السعة الكلية</h6>
                        <h2 class="mb-0 fw-bold">@ViewBag.TotalCapacity</h2>
                    </div>
                    <i class="fas fa-users fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    {{!-- ✅ Charts --}}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <div class="row g-4 mb-5">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">
                        <i class="fas fa-chart-bar text-primary me-2"></i>
                        الحجوزات مقابل الطاقة الاستيعابية
                    </h5>
                    <canvas id="bookingsChart" height="120"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">
                        <i class="fas fa-chart-pie text-success me-2"></i>
                        نسبة الامتلاء الكلي
                    </h5>
                    <canvas id="fillRateChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <script>
        const titles   = @Html.Raw(ViewBag.EventTitles);
        const bookings = @Html.Raw(ViewBag.BookingCounts);
        const limits   = @Html.Raw(ViewBag.Capacities);

        new Chart(document.getElementById('bookingsChart'), {
            type: 'bar',
            data: {
                labels: titles,
                datasets: [
                    { label: 'الحجوزات النشطة',    data: bookings, backgroundColor: 'rgba(59,130,246,0.7)', borderRadius: 6 },
                    { label: 'الطاقة الاستيعابية', data: limits,   backgroundColor: 'rgba(16,185,129,0.4)', borderRadius: 6 }
                ]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'top' } },
                scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
            }
        });

        const totalBooked   = bookings.reduce((a, b) => a + b, 0);
        const totalCapacity = limits.reduce((a, b) => a + b, 0);
        const totalFree     = totalCapacity - totalBooked;

        new Chart(document.getElementById('fillRateChart'), {
            type: 'doughnut',
            data: {
                labels: ['محجوزة', 'متاحة'],
                datasets: [{ data: [totalBooked, totalFree], backgroundColor: ['rgba(59,130,246,0.8)', 'rgba(229,231,235,0.8)'], borderWidth: 2 }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom' },
                    tooltip: {
                        callbacks: {
                            label: ctx => {
                                const pct = totalCapacity > 0 ? ((ctx.parsed / totalCapacity) * 100).toFixed(1) : 0;
                                return ` ${ctx.label}: ${ctx.parsed} (${pct}%)`;
                            }
                        }
                    }
                }
            }
        });
    </script>

    {{!-- ✅ قائمة الفعاليات --}}
    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-light rounded-3 shadow-sm">
            <div class="mb-3"><i class="fas fa-folder-open fa-4x text-muted opacity-50"></i></div>
            <h4 class="text-muted">لا توجد فعاليات مضافة حالياً</h4>
            <p class="text-muted">ابدأ بإضافة أول فعالية من الزر في الأعلى.</p>
        </div>
    }
    else
    {
        <h5 class="text-muted mb-3"><i class="fas fa-list"></i> قائمة الفعاليات</h5>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var ev in Model)
            {
                bool isPast = (ev.Date.Date + ev.StartTime) < DateTime.Now;
                string headerClass = isPast ? "bg-secondary" : "bg-success";

                <div class="col">
                    <div class="card h-100 border-0 shadow-sm hover-effect">

                        <div class="card-header text-white py-3 @headerClass">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title mb-0 text-truncate fw-bold w-75" title="@ev.Title">
                                    <i class="fas fa-calendar-day me-2"></i>@ev.Title
                                </h5>
                                @if (isPast)
                                {
                                    <small class="badge bg-dark">منتهية</small>
                                }
                        </div>
                    </div>

                    <div class="card-body bg-white">
                        <p class="card-text text-muted mb-4 small border-bottom pb-3" style="min-height: 40px;">
                            @(ev.Description != null && ev.Description.Length > 80
                                                    ? ev.Description.Substring(0, 80) + "..."
                                                    : ev.Description)
                            </p>
                            <div class="vstack gap-2 small">
                                <div class="d-flex align-items-center text-secondary">
                                    <div class="icon-box"><i class="far fa-calendar-alt text-primary"></i></div>
                                    <span class="ms-2 fw-semibold">@ev.Date.ToString("yyyy-MM-dd")</span>
                                </div>
                                <div class="d-flex align-items-center text-secondary">
                                    <div class="icon-box"><i class="far fa-clock text-primary"></i></div>
                                    <span class="ms-2">@ev.StartTime.ToString(@"hh\:mm")</span>
                                </div>
                                <div class="d-flex align-items-center text-secondary">
                                    <div class="icon-box"><i class="fas fa-map-marker-alt text-danger"></i></div>
                                    <span class="ms-2 text-truncate">@ev.Location</span>
                                </div>
                                <div class="d-flex align-items-center text-secondary">
                                    <div class="icon-box"><i class="fas fa-chair text-warning"></i></div>
                                    <span class="ms-2">السعة: <strong>@ev.Limit</strong></span>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-top-0 p-3 pt-0">
                            <hr class="mt-0 mb-3 text-muted opacity-25">
                            <div class="d-grid gap-2">
                                <a asp-action="ViewStudents" asp-route-id="@ev.Id" class="btn btn-outline-primary btn-sm fw-bold">
                                    <i class="fas fa-users-cog me-1"></i> إدارة المسجلين
                                </a>
                                <div class="d-flex gap-2">
                                    <a asp-action="EditEvent" asp-route-id="@ev.Id" class="btn btn-outline-secondary btn-sm flex-grow-1">
                                        <i class="fas fa-edit"></i> تعديل
                                    </a>
                                    {{!-- ✅ زر تصدير Excel --}}
                                    <a asp-action="ExportBookings" asp-route-eventId="@ev.Id" class="btn btn-outline-success btn-sm flex-grow-1">
                                        <i class="fas fa-file-excel"></i> Excel
                                    </a>
                                    <a asp-action="DeleteEvent" asp-route-id="@ev.Id" class="btn btn-outline-danger btn-sm flex-grow-1">
                                        <i class="fas fa-trash-alt"></i> حذف
                                    </a>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }

</div>

<style>
    .icon-box {
        width: 25px;
        text-align: center;
    }

    .hover-effect {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .hover-effect:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .hover-scale {
        transition: transform 0.2s;
    }

        .hover-scale:hover {
            transform: scale(1.05);
        }

    .card {
        border-radius: 10px;
        overflow: hidden;
    }
</style>