@model project.Models.Event
@{
    ViewBag.Title = "تأكيد الحذف";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0 text-center fw-bold">
                        <i class="fas fa-exclamation-triangle me-2"></i> تأكيد الحذف
                    </h4>
                </div>
                <div class="card-body p-4 text-center">
                    <h5 class="mb-3">هل أنت متأكد من رغبتك في حذف هذه الفعالية؟</h5>
                    <div class="alert alert-light border">
                        <h3 class="text-danger fw-bold">@Model.Title</h3>
                        <p class="text-muted">@Model.Date.ToString("yyyy-MM-dd")</p>
                    </div>
                    <p class="text-danger small">لا يمكن التراجع عن هذا الإجراء وسيتم حذف جميع سجلات الطلاب المسجلين.</p>

                    <form asp-action="DeleteEvent" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2 d-md-flex justify-content-center mt-4">
                            <a asp-action="Dashboard" class="btn btn-secondary px-4">تراجع</a>
                            <button type="submit" class="btn btn-danger px-5 fw-bold">نعم، احذف الفعالية</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>